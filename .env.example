# ============================================================
# REQUIRED — Koda won't start without these
# ============================================================

DISCORD_BOT_TOKEN=              # Create at discord.com/developers → Bot → Token

# ============================================================
# DISCORD — configure your channels
# ============================================================

DISCORD_ALLOWED_CHANNELS=       # Channel ID(s) where Koda listens (comma-separated)
DISCORD_PROACTIVE_CHANNEL=      # Channel ID for agent-initiated messages (daily digest, startup)
DISCORD_PUBLISH_CHANNEL=        # Channel ID for publish approvals (optional, separate from chat)
DISCORD_ALLOWED_USERS=          # Restrict to specific user IDs (blank = anyone in allowed channels)
DISCORD_MENTION_ONLY=false      # true = only respond when @mentioned

# ============================================================
# KODA RUNTIME
# ============================================================

TICK_INTERVAL_MS=900000         # Autonomous tick interval in ms (900000 = 15 min, 0 = disabled)

# ============================================================
# EVERYTHING BELOW IS OPTIONAL
# Add one service at a time. Koda works with just Discord.
# ============================================================

# --- X / Twitter (developer.x.com → create app → OAuth 1.0a) ---
# X_CONSUMER_KEY=
# X_CONSUMER_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=
# X_BEARER_TOKEN=
# X_EMAIL=                      # For Playwright browser automation (quote tweets, X articles)
# X_PASSWORD=                   # Wrap in quotes if it has special chars: "p@ss$word"

# --- Bluesky ---
# BLUESKY_HANDLE=user.bsky.social
# BLUESKY_APP_PASSWORD=         # Settings → App Passwords → Generate

# --- Meta (Instagram + Facebook) ---
# META_ACCESS_TOKEN=            # Graph API long-lived token
# META_APP_SECRET=
# META_PAGE_ID=
# INSTAGRAM_BUSINESS_ACCOUNT_ID=

# --- TikTok ---
# TIKTOK_SESSION_ID=            # Session cookie for upload automation

# --- YouTube ---
# YOUTUBE_MCP_PYTHON=           # Path to python with youtube-mcp deps installed

# --- Skool ---
# SKOOL_EMAIL=
# SKOOL_PASSWORD=               # Wrap in quotes if special chars
# SKOOL_GROUP_ID=               # Your group slug (e.g., build-automate)

# --- Notipo (Notion → WordPress publishing) ---
# NOTIPO_API_KEY=
# NOTIPO_URL=https://notipo.com
# NOTIPO_EMAIL=
# NOTIPO_PASSWORD=

# --- AI Image & Video Generation ---
# GEMINI_API_KEY=               # Google AI Studio → API Keys
# KLING_ACCESS_KEY=             # Kling AI video generation
# KLING_SECRET_KEY=
# FAL_KEY=                      # fal.ai image/video generation
# PEXELS_API_KEY=               # Stock photos

# --- AI Voice & Audio ---
# ELEVENLABS_API_KEY=           # Voice cloning + TTS

# --- Cross-posting ---
# DEVTO_API_KEY=                # dev.to article cross-posting

# --- GitHub Webhooks ---
# WEBHOOK_PORT=3847
# WEBHOOK_SECRET=               # Match your GitHub webhook config

# --- MCP Server Paths (defaults work on Mac, set for custom installs) ---
# X_MCP_PATH=
# GMAIL_MCP_PYTHON=
# GMAIL_MCP_PATH=
# AIRTABLE_MCP_COMMAND=
# SKOOL_SYNC_PATH=
