# Auth: SDK uses your Claude CLI login (Max subscription) — no API key needed
# API keys: loaded from ~/code/content-hub/.env automatically
# Only add overrides or koda-specific vars here

DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_CHANNELS=       # comma-separated channel IDs for conversations
DISCORD_PROACTIVE_CHANNEL=      # channel ID for agent-initiated messages (optional)
DISCORD_MENTION_ONLY=false      # set to true to only respond when @mentioned

# Webhook server for GitHub events
WEBHOOK_PORT=3847
WEBHOOK_SECRET=                 # GitHub webhook secret (optional but recommended)

# Autonomous tick loop
TICK_INTERVAL_MS=300000         # 5 minutes between ticks (default)

# Paths (defaults work on Mac, set these for VPS deployment)
# CONTENT_HUB_DIR=/path/to/content-hub
# X_MCP_PATH=/path/to/x_mcp_server.py
# GMAIL_MCP_PYTHON=/path/to/gmail-mcp/.venv/bin/python
# GMAIL_MCP_PATH=/path/to/gmail-mcp/server.py
# AIRTABLE_MCP_COMMAND=/path/to/run-airtable-mcp.sh
# SKOOL_SYNC_PATH=/path/to/skool-airtable-sync.py
# BLUESKY_HANDLE=user.bsky.social
