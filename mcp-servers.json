{
  "content-hub": {
    "command": "python3",
    "args": ["$CONTENT_HUB_DIR/servers/content_hub_mcp_server.py"]
  },
  "context7": {
    "command": "npx",
    "args": ["-y", "@upstash/context7-mcp"]
  },
  "youtube": {
    "command": "youtube-studio-mcp",
    "args": []
  },
  "x-mcp": {
    "command": "python3",
    "args": ["$CONTENT_HUB_DIR/servers/x_mcp_server.py"]
  },
  "bluesky-mcp": {
    "command": "npx",
    "args": ["-y", "@semihberkay/bluesky-mcp"],
    "env": {
      "BLUESKY_IDENTIFIER": "$BLUESKY_HANDLE",
      "BLUESKY_PASSWORD": "$BLUESKY_APP_PASSWORD"
    }
  },
  "gmail": {
    "command": "$GMAIL_MCP_PYTHON",
    "args": ["$GMAIL_MCP_PATH"],
    "defaults": {
      "GMAIL_MCP_PYTHON": "/Users/YOUR_USERNAME/code/gmail-mcp/.venv/bin/python",
      "GMAIL_MCP_PATH": "/Users/YOUR_USERNAME/code/gmail-mcp/server.py"
    }
  },
  "airtable": {
    "command": "$AIRTABLE_MCP_COMMAND",
    "args": [],
    "defaults": {
      "AIRTABLE_MCP_COMMAND": "/Users/YOUR_USERNAME/code/n8n-assistant/scripts/run-airtable-mcp.sh"
    }
  }
}
