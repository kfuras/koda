{
  "name": "koda-agent",
  "version": "0.1.0",
  "description": "Personal AI assistant built on Claude Agent SDK. Runs 24/7 on your machine with Discord as the control plane.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "author": "Kjetil Furas <kjetil.furaas@gmail.com>",
  "homepage": "https://github.com/kfuras/koda",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kfuras/koda.git"
  },
  "keywords": [
    "ai-agent",
    "claude",
    "anthropic",
    "agent-sdk",
    "autonomous",
    "discord-bot",
    "mcp",
    "marketing-automation"
  ],
  "bin": {
    "koda": "dist/koda.js"
  },
  "files": [
    "dist/",
    "templates/",
    "docs/",
    "scripts/",
    "ecosystem.config.cjs",
    "install.sh",
    "AGENTS.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/koda.js",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "cli": "tsx src/cli.ts",
    "koda": "tsx src/koda.ts",
    "daemon": "pm2 start ecosystem.config.cjs",
    "daemon:stop": "pm2 stop koda",
    "daemon:restart": "pm2 restart koda",
    "daemon:logs": "pm2 logs koda",
    "daemon:status": "pm2 status"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.111",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.2",
    "discord.js": "^14.16.0",
    "dotenv": "^17.4.1",
    "node-cron": "^4.2.1",
    "prism-media": "^1.3.5",
    "sodium-native": "^5.1.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "tar": "^7.5.13"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2"
  }
}
